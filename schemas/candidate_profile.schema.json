{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CandidateProfile",
  "description": "Structured candidate profile extracted from Markdown CV by LLM",
  "type": "object",
  "properties": {
    "personal": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "default": "" },
        "email": { "type": "string", "default": "" },
        "phone": { "type": "string", "default": "" },
        "location": { "type": "string", "default": "", "description": "Current city/country" },
        "linkedin_url": { "type": "string", "default": "" },
        "github_url": { "type": "string", "default": "" },
        "website_url": { "type": "string", "default": "" },
        "nationality": { "type": "string", "default": "", "description": "For visa assessment" },
        "languages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "language": { "type": "string" },
              "level": { "type": "string", "description": "native/fluent/professional/basic or CEFR" }
            }
          },
          "default": []
        }
      }
    },
    "target": {
      "type": "object",
      "description": "What the candidate is looking for",
      "properties": {
        "roles": { "type": "array", "items": { "type": "string" }, "default": [] },
        "roles_de": { "type": "array", "items": { "type": "string" }, "default": [] },
        "locations": { "type": "array", "items": { "type": "string" }, "default": [] },
        "work_mode": { "type": "string", "enum": ["remote", "hybrid", "onsite", "flexible", ""], "default": "" },
        "salary_expectation": { "type": "string", "default": "" },
        "visa_needed": { "type": "boolean", "default": false },
        "earliest_start": { "type": "string", "default": "" },
        "industries": { "type": "array", "items": { "type": "string" }, "default": [] },
        "dealbreakers": { "type": "array", "items": { "type": "string" }, "default": [] }
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "degree": { "type": "string", "default": "" },
          "field": { "type": "string", "default": "" },
          "institution": { "type": "string", "default": "" },
          "location": { "type": "string", "default": "" },
          "start_date": { "type": "string", "default": "" },
          "end_date": { "type": "string", "default": "" },
          "thesis_topic": { "type": "string", "default": "" },
          "gpa": { "type": "string", "default": "" }
        }
      },
      "default": []
    },
    "experience": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "default": "" },
          "company": { "type": "string", "default": "" },
          "location": { "type": "string", "default": "" },
          "start_date": { "type": "string", "default": "" },
          "end_date": { "type": "string", "default": "" },
          "description": { "type": "string", "default": "" },
          "technologies": { "type": "array", "items": { "type": "string" }, "default": [] }
        }
      },
      "default": []
    },
    "skills": {
      "type": "object",
      "properties": {
        "technical": { "type": "array", "items": { "type": "string" }, "default": [] },
        "frameworks": { "type": "array", "items": { "type": "string" }, "default": [] },
        "domains": { "type": "array", "items": { "type": "string" }, "default": [] },
        "soft": { "type": "array", "items": { "type": "string" }, "default": [] },
        "certifications": { "type": "array", "items": { "type": "string" }, "default": [] }
      }
    },
    "publications": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "default": "" },
          "venue": { "type": "string", "default": "" },
          "year": { "type": "string", "default": "" },
          "url": { "type": "string", "default": "" }
        }
      },
      "default": []
    },
    "story": {
      "type": "string",
      "default": "",
      "description": "150-300 word narrative summary of the candidate, generated by LLM from CV"
    }
  }
}
