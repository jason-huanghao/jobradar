# JobRadar — LLM API key configuration
#
# JobRadar checks these sources in order (first found wins):
#   1. OPENCLAW_API_KEY   — auto-detected when running as an OpenClaw skill
#   2. Claude OAuth       — auto-detected from ~/.claude/.credentials.json
#                           (free if you have a Claude Code / claude.ai subscription)
#   3. Any key below

# Uncomment and fill in your preferred provider:
ARK_API_KEY=your_volcengine_ark_key_here

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# ZAI_API_KEY=...
# DEEPSEEK_API_KEY=...
# OPENROUTER_API_KEY=...

# ── CN platforms (only needed if enabling Boss直聘) ───────────────────────────
# BOSSZHIPIN_COOKIES=__zp_stoken__=xxx; wt2=yyy
